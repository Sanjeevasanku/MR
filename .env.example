# Server (detect + dashboard + fix — all on one port)
PORT=3000
NODE_ENV=development

# GitLab
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_token

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# MongoDB (optional — omit to run detect-only without dashboard)
MONGODB_URI=mongodb://127.0.0.1:27017/ai-review-poc

# Review trigger control
REQUIRE_ANALYSIS_LABEL=true
ANALYSIS_LABEL=analysis
